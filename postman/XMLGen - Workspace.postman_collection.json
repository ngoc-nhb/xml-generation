{
  "info": {
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
    "name": "XMLGen - Workspace",
    "description": "Workspace CRUD APIs for XMLGen Phase 7.1.3.\n\nRun **Authentication > Login** from the Template collection first.\n\nPaths: `/api/v1/workspaces`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'X-Workspace-Id', value: pm.environment.get('workspaceId') || '1' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "List Workspaces",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/workspaces?page=1&pageSize=20"
          }
        },
        {
          "name": "Create Workspace",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const body = pm.response.json();",
                "if (body.success && body.data && body.data.id) {",
                "  pm.environment.set('workspaceId', String(body.data.id));",
                "  pm.environment.set('workspaceCode', body.data.code || '');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"WS_{{$timestamp}}\",\n  \"name\": \"Test Workspace\",\n  \"description\": \"Created from Postman\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/workspaces"
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "Update Workspace",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Workspace Updated\",\n  \"description\": \"Updated from Postman\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "Delete Default Workspace (expect failure)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/workspaces/1"
          }
        },
        {
          "name": "Create Duplicate Code (expect failure)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"DEFAULT\",\n  \"name\": \"Duplicate\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/workspaces"
          }
        }
      ]
    }
  ]
}
