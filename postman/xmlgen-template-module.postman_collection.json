            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"typeId\": {{masterDataTypeId}},\n  \"code\": \"game_kind_id\",\n  \"name\": \"Game Kind ID\",\n  \"dataType\": \"INTEGER\",\n  \"required\": true,\n  \"displayOrder\": 1,\n  \"description\": null,\n  \"defaultValue\": null,\n  \"unique\": true,\n  \"searchable\": true,\n  \"masterDataReferenceTypeId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/master-data/fields",
              "host": [
