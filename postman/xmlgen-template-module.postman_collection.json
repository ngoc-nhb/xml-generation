{
  "info": {
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
    "name": "XMLGen - Template Module",
    "description": "Postman collection for XMLGen Template Module APIs (v0.4.0).\n\nPrerequisites:\n1. Import `xmlgen-local.postman_environment.json`\n2. Start the app with `./gradlew bootRun`\n3. Run **Authentication > Login** first\n4. For MASTER_DATA mapping flows, run **Setup > Master Data** requests before template schema requests\n\nProtected requests use `Authorization: Bearer {{accessToken}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "templateId",
      "value": ""
    },
    {
      "key": "templateCode",
      "value": ""
    },
    {
      "key": "masterDataTypeId",
      "value": ""
    },
    {
      "key": "masterDataFieldId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login succeeds', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.eql(true);",
                  "    pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('accessToken', body.data.accessToken);",
                  "    pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Obtain JWT access token for protected Template APIs."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Setup",
      "description": "Optional Master Data setup required before creating template mappings to MASTER_DATA fields.",
      "item": [
        {
          "name": "Create Master Data Type",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('masterDataTypeCode', 'GAME_KIND_' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('master data type created', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.eql(true);",
                  "    pm.expect(body.data.id).to.be.a('number');",
                  "    pm.environment.set('masterDataTypeId', String(body.data.id));",
                  "    pm.collectionVariables.set('masterDataTypeId', String(body.data.id));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{masterDataTypeCode}}\",\n  \"name\": \"Game Kind\",\n  \"description\": \"Sample master data type for template mapping\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/master-data/types",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "master-data",
                "types"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Master Data Field",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('master data field created', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.eql(true);",
                  "    pm.expect(body.data.id).to.be.a('number');",
